{
  "compilerOptions": {
    "esModuleInterop": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "commonjs",
    "target": "es2019",
    "jsx": "react",
    "lib": ["dom", "esnext"],
    "types": ["vitest/globals", "node"],
    "rootDir": "./src",
    "outDir": "./dist/",
    "baseUrl": "./src"
  },
  "watchOptions": {
    "excludeDirectories": ["**/node_modules", "dist"]
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "eslint.config.mjs"],
  "exclude": ["node_modules"]
}
